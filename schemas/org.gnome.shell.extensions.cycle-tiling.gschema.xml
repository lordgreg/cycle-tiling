<?xml version="1.0" encoding="UTF-8" ?>
<schemalist>
  <schema
    id="org.gnome.shell.extensions.cycle-tiling"
    path="/org/gnome/shell/extensions/cycle-tiling/"
  >

    <!-- Actual keybindings (read by addKeybinding) -->
    <key name="cycle-tiling-left" type="as">
      <default><![CDATA[['<Super>Left', '<Alt><Shift>q']]]></default>
      <summary>Move window left</summary>
      <description>Cycle size focus window to the left</description>
    </key>

    <key name="cycle-tiling-right" type="as">
      <default><![CDATA[['<Super>Right', '<Alt><Shift>r']]]></default>
      <summary>Move window right</summary>
      <description>Cycle size focus window to the right</description>
    </key>

    <key name="cycle-tiling-maximize" type="as">
      <default><![CDATA[['<Super>Up', '<Alt><Shift>w']]]></default>
      <summary>Maximize window</summary>
      <description>Maximize focused window</description>
    </key>

    <key name="cycle-tiling-restore" type="as">
      <default><![CDATA[['<Super>Down', '<Alt><Shift>e']]]></default>
      <summary>Restore initial window size</summary>
      <description>Restore focused window size</description>
    </key>
  </schema>
</schemalist>
